{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Flask Debug (Universal)",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "python": "${workspaceFolder}/.venv/Scripts/python.exe",
            "args": [
                "run",
                "--port", "3000"
            ],
            "console": "integratedTerminal",
            "env": {
                "FLASK_APP": "src/server.py",
                "FLASK_DEBUG": "1",
                "PYTHONPATH": "${workspaceFolder}/src"
            }
        }
    ]
}